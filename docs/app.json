[{"name":"app.R","content":"# ====================================================\r\n# SVM骨质疏松风险计算器 - 完整app.R代码\r\n# ====================================================\r\n\r\nlibrary(shiny)\r\nlibrary(shinythemes)\r\n\r\n# 定义UI\r\nui <- fluidPage(\r\n  theme = shinytheme(\"cosmo\"),\r\n  \r\n  # 应用标题\r\n  titlePanel(\"🦴 类风湿关节炎患者骨质疏松风险计算器 (SVM模型)\"),\r\n  \r\n  sidebarLayout(\r\n    sidebarPanel(\r\n      h4(\"患者基本信息\"),\r\n      \r\n      selectInput(\"menopause\", \"绝经状态:\",\r\n                  choices = list(\"未绝经\" = 0, \"已绝经\" = 1),\r\n                  selected = 1),\r\n      \r\n      numericInput(\"age\", \"年龄 (岁):\",\r\n                   value = 50, min = 18, max = 100, step = 1),\r\n      \r\n      numericInput(\"bmi\", \"BMI (kg/m²):\",\r\n                   value = 24, min = 15, max = 45, step = 0.5),\r\n      \r\n      numericInput(\"calcium\", \"血钙 (mmol/L):\",\r\n                   value = 2.2, min = 1.5, max = 3.0, step = 0.1),\r\n      \r\n      hr(),\r\n      h4(\"疾病相关指标\"),\r\n      \r\n      numericInput(\"das28_esr\", \"DAS28-ESR:\",\r\n                   value = 3.0, min = 1.0, max = 9.0, step = 0.1),\r\n      \r\n      numericInput(\"acpa\", \"ACPA (U/mL):\",\r\n                   value = 0, min = 0, max = 500, step = 1),\r\n      \r\n      numericInput(\"disease_duration\", \"病程 (年):\",\r\n                   value = 5, min = 0, max = 50, step = 0.5),\r\n      \r\n      hr(),\r\n      h4(\"用药史\"),\r\n      \r\n      numericInput(\"gc_cumulative_dose\", \"激素累积量 (g):\",\r\n                   value = 0, min = 0, max = 100, step = 0.1),\r\n      \r\n      selectInput(\"gc_longterm\", \"激素长期使用 (≥3个月):\",\r\n                  choices = list(\"否\" = 0, \"是\" = 1),\r\n                  selected = 0),\r\n      \r\n      selectInput(\"ppi\", \"PPI使用:\",\r\n                  choices = list(\"否\" = 0, \"是\" = 1),\r\n                  selected = 0),\r\n      \r\n      br(),\r\n      actionButton(\"calculate\", \"计算风险\", \r\n                   class = \"btn-primary btn-lg btn-block\",\r\n                   style = \"background-color: #ff7f0e; border-color: #ff7f0e;\"),\r\n      \r\n      br(),\r\n      p(\"模型性能: AUC = 0.8721 | 灵敏度 = 0.8966 | 特异度 = 0.7368\", \r\n        style = \"font-size: 12px; color: gray; text-align: center;\")\r\n    ),\r\n    \r\n    mainPanel(\r\n      h3(\"预测结果\"),\r\n      br(),\r\n      \r\n      wellPanel(\r\n        uiOutput(\"result_display\"),\r\n        br(),\r\n        htmlOutput(\"risk_class\")\r\n      ),\r\n      \r\n      br(),\r\n      h4(\"使用说明\"),\r\n      p(\"本计算器基于支持向量机(SVM)模型，用于评估类风湿关节炎患者骨质疏松风险。\"),\r\n      p(\"请完整填写左侧所有信息后点击'计算风险'按钮。\"),\r\n      p(\"结果仅供临床参考，如有疑问请咨询医生。\")\r\n    )\r\n  )\r\n)\r\n\r\n# 定义Server\r\nserver <- function(input, output) {\r\n  \r\n  # 加载SVM参数\r\nsvm_params <- readRDS(\"svm_params.rds\")\r\n# RBF核函数（增强调试版）\r\nrbf_kernel <- function(x1, x2, gamma) {\r\n  sum_sq <- sum((x1 - x2)^2)\r\n  result <- exp(-gamma * sum_sq)\r\n  return(result)\r\n}\r\n\r\n# SVM决策函数（带调试）\r\nsvm_decision <- function(features, svm_params) {\r\n  decision <- -svm_params$intercept\r\n  for (i in 1:nrow(svm_params$support_vectors)) {\r\n    sv <- svm_params$support_vectors[i, ]\r\n    coef <- svm_params$coefs[i]\r\n    kernel_val <- rbf_kernel(features, sv, svm_params$gamma)\r\n    decision <- decision + coef * kernel_val\r\n  }\r\n  return(decision)\r\n}\r\n\r\n# Platt scaling转换为概率\r\nplatt_sigmoid <- function(decision_value, platt_A, platt_B) {\r\n  return(1 / (1 + exp(-(platt_A * decision_value + platt_B))))\r\n}\r\n  \r\n  # 计算风险\r\n  observeEvent(input$calculate, {\r\n    \r\n    # 收集原始输入值\r\n    raw_features <- c(\r\n      as.numeric(input$menopause),\r\n      input$age,\r\n      input$gc_cumulative_dose,\r\n      input$das28_esr,\r\n      input$acpa,\r\n      input$calcium,\r\n      input$bmi,\r\n      as.numeric(input$ppi),\r\n      input$disease_duration,\r\n      as.numeric(input$gc_longterm)\r\n    )\r\n    \r\n    # ===== 标准化输入特征（使用真实的训练数据均值和标准差）=====\r\n    feature_means <- c(0.6087, 61.0815, 4511.269, 3.7984, 112.65, 2.1803, 23.3109, 0.1413, 9.7987, 0.3261)\r\n    feature_sds <- c(0.4894, 12.2559, 10817.8825, 1.2421, 93.1757, 0.1178, 3.8896, 0.3493, 10.5656, 0.4701)\r\n    \r\n    # 标准化\r\n    features <- (raw_features - feature_means) / feature_sds\r\n    # ===================================\r\n    \r\n  # 计算决策值\r\ndecision_val <- svm_decision(features, svm_params)\r\n# 转换为概率\r\nprob <- platt_sigmoid(decision_val, svm_params$platt_A, svm_params$platt_B)\r\n    \r\n    # 显示结果\r\n    output$result_display <- renderUI({\r\n      tags$div(\r\n        style = \"text-align: center;\",\r\n        h4(\"骨质疏松风险概率\"),\r\n        h2(paste0(round(prob * 100, 1), \"%\"), \r\n           style = paste0(\"color: \", ifelse(prob > 0.5, \"#d62728\", \"#2ca02c\"), \"; font-weight: bold;\"))\r\n      )\r\n    })\r\n    \r\n    output$risk_class <- renderUI({\r\n      if(prob > 0.5) {\r\n        tags$div(\r\n          class = \"alert alert-danger\",\r\n          style = \"text-align: center;\",\r\n          h4(\"高风险\"),\r\n          p(\"建议进行DXA检查和干预\")\r\n        )\r\n      } else {\r\n        tags$div(\r\n          class = \"alert alert-success\",\r\n          style = \"text-align: center;\",\r\n          h4(\"低风险\"),\r\n          p(\"定期随访，预防为主\")\r\n        )\r\n      }\r\n    })\r\n  })\r\n}\r\n\r\n# 运行应用\r\nshinyApp(ui = ui, server = server)","type":"text"},{"name":"svm_new.rds","content":"H4sIAAAAAAAABu1bCVhNW/vfDUopRQo3czJfQ1zkyjqKDJkuQsnNqXNSnAZNEhfhGstV1xUZ\nruEmipS5yFsklCiVRDRPmue5/ms7ey0c12f47vN8z/f8P8/zs/Za613veqfd+e2z11mmyDCM\nDCMrK8XIdMCXTAfjxYbfT8RjarjTB0MOQ4qRZRRw28nJ1XakQGjFdxE5M4ys9HtTUm4SslLL\n8X/vSyg6O/Jt7MwFfGc+N9MsIaFsJeQ7uzgKze34tkInPNAmucl6yU0GilXItkuoUrB3MHdy\nxtr+To3cGqGjnVCEr1TfH3XkC2z4IgnZDqv4traswZ3ZQXTuMPvPT0JI1tLeyZnKZDLcvw9k\nOjk42lvwLWxENs6sF4pvp8RoI0uZd//e9nkS/XequfmOEvPUvL/XJ7kehVF5xffkFSXs+wyk\n1cTBl2Z1KqIcd/u5RRETefP2iNvQP6e9PpLkzutsqfKHdmoZz2zo2z15UmvnxYdEGvMmzGeH\nx6A7GvoPTDr152kdKjtVrXEVJbOr7OdJ5oPUhupbI